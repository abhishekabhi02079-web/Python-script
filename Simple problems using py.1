# 2.Write a Python program that swaps the values of two variables with and without using a third variable.
#2ans with third variable
a = 10
b = 25
print('Before swapping: ')
print('a: ',a)
print('b: ',b)
#swapping using temprory variable
Temp = a
a = b
b = Temp
print('After swapping: ')
print('a: ',a)
print('b: ',b)

#2ans without third variable
a = 10
b = 25
print('Before swapping: ')
print('a: ',a)
print('b: ',b)
a,b = b,a              #use these without temprory variable
print('After swapping: ')
print('a: ',a)
print('b: ',b)


